{
  "version": 2,
  "builds": [
    {
      "src": "server/api/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/public/index.html",
          "server/public/favicon.png"
        ]
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/api/index.ts"
    },
    {
      "source": "/producto/(.*)",
      "destination": "/server/api/index.ts"
    },
    {
      "source": "/product/(.*)",
      "destination": "/server/api/index.ts"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/server/public/assets/$1"
    },
    {
      "source": "/favicon.png",
      "destination": "/server/public/favicon.png"
    },
    {
      "source": "/(.*)",
      "destination": "/server/public/index.html"
    }
  ]
}
